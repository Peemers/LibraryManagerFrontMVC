@using LibraryManagerFrontMvc.Enums
@model LibraryManagerFrontMvc.Models.LivreViewModel

@{
    ViewData["Title"] = "Poster un livre..";
}

<h1>@ViewData["Title"]</h1>

<br>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="mb-3">
                <label asp-for="Nom" class="form-label"></label>
                <input type="text" asp-for="Nom" class="form-control">
                <span asp-validation-for="Nom" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Auteur" class="form-label"></label>
                <input type="text" asp-for="Auteur" class="form-control">
                <span asp-validation-for="Auteur" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="NbPages" class="form-label"></label>
                <input type="number" asp-for="NbPages" class="form-control">
                <span asp-validation-for="NbPages" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Resume" class="form-label"></label>
                <textarea asp-for="Resume" class="form-control" style="width: 50px" ></textarea>
                <span asp-validation-for="Resume" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="DateDeSortie" class="form-label"></label>
                <input type="date" asp-for="DateDeSortie" class="form-control">
                <span asp-validation-for="DateDeSortie" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="StatutLivre" class="form-label">Statut du livre</label>
                <select asp-for="StatutLivre" class="form-select">
                    <option value="@LivreStatut.Disponible">Disponible</option>
                    <option value="@LivreStatut.NonDisponible">Non Disponible (Emprunté)</option>
                    <option value="@LivreStatut.Perdu">Perdu</option>
                </select>
                <span asp-validation-for="StatutLivre" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <input type="submit" value="Enregistrer" class="btn btn-secondary">
                <a asp-action="Index" class="btn btn-secondary">Retour</a>
            </div>
            
        </form>
    </div>
</div>
